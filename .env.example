# 答岸 · 环境变量模板
# 复制本文件为 .env 后填写真实值（.env 已被 .gitignore 忽略）

# JWT 签名密钥（请换成随机长字符串，例如 openssl rand -base64 48）
JWT_SECRET=change_me_to_a_long_random_secret_string

# 服务端口
PORT=3000

# SQLite 数据库文件路径（相对或绝对）。默认 server/data/daan.db
DB_PATH=server/data/daan.db

# 令牌时效
ACCESS_EXPIRES=2h
REFRESH_EXPIRES=7d

# 验证码（注册联系方式校验）
CODE_TTL_SECONDS=300
CODE_LENGTH=6
RESEND_INTERVAL=60
# 演示模式：true 时 /send-code 不真实发邮件、仅回显验证码到响应体。
# 生产必须设为 false（或删除该行，默认值即为 false）。
DEMO_MODE=false

# 邮件服务（Resend，真实发送验证码）
# 注册并获取 API Key：https://resend.com/api-keys
# 发件人需先在 Resend 后台验证域名或沿用 Resend 提供的 sandbox 发件域（onboarding@resend.dev 仅限测试）
RESEND_API_KEY=
MAIL_FROM=答岸 <onboarding@resend.dev>
